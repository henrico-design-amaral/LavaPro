{
  "name": "lavapro",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev apps/web",
    "build": "npm run db:generate && npm run build:seed && cd apps/web && next build",
    "start": "cd apps/web && next start",
    "db:generate": "prisma generate --schema=packages/database/prisma/schema.prisma",
    "build:seed": "tsc --project packages/database/tsconfig.json"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "latest",
    "@types/node": "latest",
    "lucide-react": "^1.14.0",
    "next": "latest",
    "pg": "^8.20.0",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/react": "latest",
    "prisma": "latest",
    "ts-node": "latest",
    "typescript": "latest"
  },
  "prisma": {
    "schema": "packages/database/prisma/schema.prisma",
    "seed": "node packages/database/dist/seed.js"
  }
}