{
  "name": "lavapro",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev apps/web",
    "start": "next start apps/web",
    "postinstall": "npm run db:generate",
    "build": "npm run db:generate && npm run build:seed && next build apps/web",
    "db:generate": "prisma generate --schema=packages/database/prisma/schema.prisma",
    "build:seed": "tsc packages/database/seed.ts --outDir packages/database/dist"
  },
  "dependencies": {
    "@prisma/client": "latest",
    "@types/node": "latest",
    "lucide-react": "^1.14.0",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@types/react": "latest",
    "prisma": "latest",
    "ts-node": "latest",
    "typescript": "latest"
  },
  "prisma": {
    "schema": "packages/database/prisma/schema.prisma",
    "seed": "node packages/database/dist/seed.js"
  }
}